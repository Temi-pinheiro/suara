{
  "expo": {
    "name": "Suara",
    "slug": "suara",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "scheme": "suara",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F8E78"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Suara listens to your practice so your tutor can give gentle feedback.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.devinhio.suara"
    },
    "android": {
      "package": "com.devinhio.suara",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F8E78"
      },
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "4f1187f2-f43d-4d6d-b4e3-c602dd1f46f9"
      }
    },
    "owner": "devinhio"
  }
}

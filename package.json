{
  "name": "suara",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:turn": "vitest run tests/turn.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "smoke": "tsx packages/server/scripts/smoke.mts",
    "db:generate": "pnpm --filter @suara/server exec drizzle-kit generate",
    "db:migrate": "pnpm --filter @suara/server exec drizzle-kit migrate",
    "db:seed": "pnpm --filter @suara/server exec tsx scripts/seed.mts",
    "turn": "pnpm --filter @suara/server exec tsx scripts/turn.mts",
    "serve": "pnpm --filter @suara/server exec tsx scripts/serve.mts",
    "gen:audio": "pnpm --filter @suara/server exec tsx scripts/gen-audio.mts",
    "dev": "echo \"dev (serverless handlers + Expo) wires up in Phase 1\" && exit 0",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "expo": "~54.0.35",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}

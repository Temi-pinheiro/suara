# Suara — required environment.
# Phase 0 runs fully on mocks; real keys are needed from Phase 1 onward.

# --- LLM (tutor brain) ---
ANTHROPIC_API_KEY=

# --- TTS / ASR (ElevenLabs) ---
ELEVENLABS_API_KEY=

# --- Pronunciation scoring (not needed for Indonesian / coached mode) ---
SPEECHSUPER_APP_KEY=
SPEECHSUPER_SECRET=
AZURE_SPEECH_KEY=
AZURE_REGION=

# --- Data: Supabase Postgres ---
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Audio cache: Cloudflare R2 (zero egress) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# --- Deploy / runtime (Edge Function — see docs/deploy.md) ---
# ElevenLabs voice ids (the edge fn reads these instead of fetching the voice list).
SUARA_TARGET_VOICE_ID=
SUARA_L1_VOICE_ID=
SUARA_LANG=cmn
# Per-user rate limits on the public endpoint (a turn ≈ 2 requests). Defaults shown.
SUARA_MAX_REQ_PER_MIN=12
SUARA_MAX_REQ_PER_HOUR=120

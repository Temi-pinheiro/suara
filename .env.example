# Suara — required environment.
# Phase 0 runs fully on mocks; real keys are needed from Phase 1 onward.

# --- LLM (tutor brain) ---
ANTHROPIC_API_KEY=

# --- TTS / ASR (ElevenLabs) ---
ELEVENLABS_API_KEY=

# --- Pronunciation scoring (not needed for Indonesian / coached mode) ---
SPEECHSUPER_APP_KEY=
SPEECHSUPER_SECRET=
AZURE_SPEECH_KEY=
AZURE_REGION=

# --- Data: Supabase Postgres ---
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Audio cache: Cloudflare R2 (zero egress) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
